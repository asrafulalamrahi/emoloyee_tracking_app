# Database
DATABASE_URL="postgresql://user:password@host:port/dbname?sslmode=require"

# JWT Auth Secret
JWT_SECRET="super-secret-jwt-key"

# Port (configured automatically by hosting providers like Render)
PORT=3000

# Environment (development or production)
NODE_ENV="production"

# Frontend URLs for CORS setup
CLIENT_URL="https://metrologix-frontend.vercel.app"
FRONTEND_URL="https://metrologix-frontend.vercel.app"

# API Base URL for frontend requests
VITE_API_URL="https://metrologix-backend.onrender.com"

